# Copy this file to .env for local development.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=deepseek/deepseek-v4-pro
SOL01_CONCURRENCY=4
SOL01_SNOWFLAKE_CREDENTIAL_PATH=snowflake_credential.json
SOL01_OLLAMA_BASE_URL=http://127.0.0.1:11434
SOL01_SCHEMA_EMBEDDING_MODEL=qwen3-embedding:4b
SOL01_SCHEMA_RERANKER_MODEL=qwen3-reranker:4b
SOL01_SCHEMA_CHUNK_TOP_K=80
SOL01_SCHEMA_RERANK_TOP_K=20
SOL01_SCHEMA_OBJECT_TOP_K=12
SOL01_SCHEMA_FAMILY_TOP_K=8
SOL01_SCHEMA_FAMILY_SIMILARITY_THRESHOLD=0.82
SOL01_SCHEMA_MAX_LINKED_DOC_CHARS=6000
SOL01_SCHEMA_MAX_PROMPT_CHARS=24000
SOL01_SCHEMA_RETRIEVAL_VERSION=hybrid_v1
